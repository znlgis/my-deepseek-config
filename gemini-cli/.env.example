# Gemini CLI × DeepSeek 环境变量示例
# 复制为 .gemini/.env（项目级）或 ~/.gemini/.env（全局），填入真实 Key。
# 需要使用支持 OpenAI 兼容 Provider 的 Gemini CLI 版本；否则请配合 LiteLLM 等代理。
# 切勿把真实 API Key 提交进仓库。

# DeepSeek 的 OpenAI 兼容端点
OPENAI_BASE_URL=https://api.deepseek.com/v1

# DeepSeek API Key（https://platform.deepseek.com 申请）
OPENAI_API_KEY=sk-your-deepseek-key

# 主模型 deepseek-reasoner（Pro）/ 轻量模型 deepseek-chat（Flash）
OPENAI_MODEL=deepseek-chat
