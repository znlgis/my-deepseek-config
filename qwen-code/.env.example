# Qwen Code × DeepSeek 环境变量示例
# 复制为 .qwen/.env（项目级）或 ~/.qwen/.env（全局），填入真实 Key 后使用。
# 切勿把真实 API Key 提交进仓库。

# DeepSeek 的 OpenAI 兼容端点
OPENAI_BASE_URL=https://api.deepseek.com/v1

# DeepSeek API Key（https://platform.deepseek.com 申请）
OPENAI_API_KEY=sk-your-deepseek-key

# 主模型（Pro / 强推理）：deepseek-reasoner
# 轻量模型（Flash / 快速）：deepseek-chat
OPENAI_MODEL=deepseek-chat
